DB_FILE_NAME=file:./data/beak-control-pane.db

# Platform admin (seeded on bootstrap if both are set; used for staff console login)
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Optional dedicated super admin seed (same platform_admin permissions)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Auth — session cookie and optional enforcement (defaults keep local dev open)
# AUTH_COOKIE_NAME=bcp_session
# AUTH_SESSION_DAYS=14
# Set to true to require staff session for console UI and /api/* (except public/SDK routes)
# AUTH_ENFORCE_CONSOLE=false
# AUTH_ENFORCE_PORTAL=false
# AUTH_ENFORCE_API=false

# Stripe (Phase 2 billing gateway)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# License signing — ECDSA P-256 (ES256), PKCS#8 private + SPKI public PEM
# openssl ecparam -name prime256v1 -genkey -noout -out ec-private.pem
# openssl ec -in ec-private.pem -pubout -out ec-public.pem
# openssl pkcs8 -topk8 -nocrypt -in ec-private.pem -out ec-private-pkcs8.pem
# BCP_LICENSE_KEY_ID - An identifier for which key was used to sign a license 
# (e.g. rotation: bcp-1, bcp-2). Verifiers pick the right public key.
BCP_LICENSE_KEY_ID=bcp-1
# BCP_LICENSE_PRIVATE_KEY_PEM - Secret. Used only where licenses are issued/signed 
# (e.g. server-side POST /api/licenses). Never commit real values; paste the PKCS#8 PEM (including BEGIN/END lines).
BCP_LICENSE_PRIVATE_KEY_PEM=
# BCP_LICENSE_PUBLIC_KEY_PEM - Public. Used to verify signatures (e.g. in apps or tests). 
# Safe to distribute in clients if your threat model allows offline verification with a known public key.
BCP_LICENSE_PUBLIC_KEY_PEM=
